---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = "Floreth — Know your body. Honor your design.", description = "Floreth is a premium Christian fertility and cycle tracking platform rooted in holistic and functional medicine. Faith-grounded wellness for women who want to understand their bodies as fearfully and wonderfully made." } = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <title>{title}</title>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Floreth",
      "description": "A premium Christian fertility and cycle tracking platform rooted in holistic and functional medicine. Faith-grounded wellness for women who want to understand their bodies as fearfully and wonderfully made.",
      "url": "https://fertile-grace.onrender.com"
    }
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-surface-50 text-surface-900 font-body antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
