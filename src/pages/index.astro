---
import Base from '../layouts/Base.astro';
import EmailCapture from '../components/EmailCapture.astro';
---

<Base
  title="Floreth — Finally understand your cycle, naturally"
  description="Floreth is a premium fertility awareness and cycle health platform rooted in functional medicine. Hormone-free fertility tracking, cycle syncing, and holistic body literacy for every woman."
>

  <!-- ═══════════════════════════════════════════════════════════════════
       HERO — Full-colour botanical illustration, vibrant Rifle Paper Co. palette
  ══════════════════════════════════════════════════════════════════════ -->
  <section class="hero-section relative min-h-[96vh] flex flex-col items-center justify-center overflow-hidden" style="background:#FDFAF5;">

    <div class="hero-bg absolute inset-0" aria-hidden="true"></div>
    <div class="hero-grain absolute inset-0" aria-hidden="true"></div>

    <!-- Top-right bold floral cluster -->
    <div class="absolute top-0 right-0 w-[300px] md:w-[460px] lg:w-[540px] pointer-events-none select-none" aria-hidden="true" style="transform:translate(8%,-4%);">
      <svg viewBox="0 0 540 500" fill="none" xmlns="http://www.w3.org/2000/svg">
        <ellipse cx="400" cy="105" rx="50" ry="36" transform="rotate(-30 400 105)" fill="#E05A3A" opacity="0.92"/>
        <ellipse cx="400" cy="105" rx="50" ry="36" transform="rotate(42 400 105)"  fill="#E05A3A" opacity="0.80"/>
        <ellipse cx="400" cy="105" rx="50" ry="36" transform="rotate(114 400 105)" fill="#E05A3A" opacity="0.80"/>
        <ellipse cx="400" cy="105" rx="50" ry="36" transform="rotate(186 400 105)" fill="#E05A3A" opacity="0.72"/>
        <ellipse cx="400" cy="105" rx="50" ry="36" transform="rotate(258 400 105)" fill="#E05A3A" opacity="0.72"/>
        <circle  cx="400" cy="105" r="17" fill="#F5C842"/>
        <circle  cx="400" cy="105" r="8"  fill="#E05A3A"/>
        <ellipse cx="305" cy="62"  rx="36" ry="24" transform="rotate(-20 305 62)"  fill="#E8527A" opacity="0.90"/>
        <ellipse cx="305" cy="62"  rx="36" ry="24" transform="rotate(52 305 62)"   fill="#E8527A" opacity="0.76"/>
        <ellipse cx="305" cy="62"  rx="36" ry="24" transform="rotate(124 305 62)"  fill="#E8527A" opacity="0.76"/>
        <ellipse cx="305" cy="62"  rx="36" ry="24" transform="rotate(196 305 62)"  fill="#E8527A" opacity="0.68"/>
        <circle  cx="305" cy="62"  r="12" fill="#F5C842"/>
        <circle  cx="305" cy="62"  r="5.5" fill="#E8527A"/>
        <ellipse cx="470" cy="210" rx="42" ry="28" transform="rotate(15 470 210)"  fill="#F5C842" opacity="0.92"/>
        <ellipse cx="470" cy="210" rx="42" ry="28" transform="rotate(87 470 210)"  fill="#F5C842" opacity="0.80"/>
        <ellipse cx="470" cy="210" rx="42" ry="28" transform="rotate(159 470 210)" fill="#F5C842" opacity="0.80"/>
        <ellipse cx="470" cy="210" rx="42" ry="28" transform="rotate(231 470 210)" fill="#F5C842" opacity="0.70"/>
        <circle  cx="470" cy="210" r="14" fill="#E05A3A"/>
        <circle  cx="470" cy="210" r="6.5" fill="#F5C842"/>
        <ellipse cx="355" cy="162" rx="34" ry="13" transform="rotate(-50 355 162)" fill="#6B8F5E" opacity="0.82"/>
        <ellipse cx="422" cy="168" rx="28" ry="11" transform="rotate(20 422 168)"  fill="#6B8F5E" opacity="0.74"/>
        <ellipse cx="334" cy="76"  rx="24" ry="9"  transform="rotate(-65 334 76)"  fill="#6B8F5E" opacity="0.70"/>
        <ellipse cx="450" cy="142" rx="20" ry="8"  transform="rotate(35 450 142)"  fill="#6B8F5E" opacity="0.66"/>
        <path d="M400 142 C395 192 380 232 366 280" stroke="#6B8F5E" stroke-width="2" fill="none" stroke-linecap="round" opacity="0.55"/>
        <path d="M305 86  C296 122 286 152 276 192"  stroke="#6B8F5E" stroke-width="1.5" fill="none" stroke-linecap="round" opacity="0.48"/>
        <ellipse cx="272" cy="200" rx="13" ry="9" transform="rotate(-25 272 200)" fill="#E8527A" opacity="0.72"/>
        <circle  cx="272" cy="200" r="5" fill="#F5C842" opacity="0.88"/>
        <circle cx="342" cy="48" r="5"  fill="#F5C842" opacity="0.82"/>
        <circle cx="444" cy="82" r="4"  fill="#E8527A" opacity="0.72"/>
        <circle cx="378" cy="244" r="4" fill="#E05A3A" opacity="0.68"/>
      </svg>
    </div>

    <!-- Bottom-left botanical sprig -->
    <div class="absolute bottom-0 left-0 w-[200px] md:w-[300px] pointer-events-none select-none" aria-hidden="true" style="transform:translate(-4%,5%);">
      <svg viewBox="0 0 300 260" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M28 260 C55 222 92 188 130 148 C158 116 172 82 196 48" stroke="#6B8F5E" stroke-width="2" fill="none" stroke-linecap="round" opacity="0.65"/>
        <ellipse cx="72"  cy="232" rx="26" ry="10" transform="rotate(45 72 232)"   fill="#6B8F5E" opacity="0.76"/>
        <ellipse cx="104" cy="196" rx="22" ry="9"  transform="rotate(-20 104 196)" fill="#6B8F5E" opacity="0.70"/>
        <ellipse cx="140" cy="158" rx="24" ry="9"  transform="rotate(40 140 158)"  fill="#6B8F5E" opacity="0.72"/>
        <ellipse cx="160" cy="122" rx="30" ry="21" transform="rotate(-15 160 122)" fill="#E8527A" opacity="0.84"/>
        <ellipse cx="160" cy="122" rx="30" ry="21" transform="rotate(57 160 122)"  fill="#E8527A" opacity="0.72"/>
        <ellipse cx="160" cy="122" rx="30" ry="21" transform="rotate(129 160 122)" fill="#E8527A" opacity="0.72"/>
        <ellipse cx="160" cy="122" rx="30" ry="21" transform="rotate(201 160 122)" fill="#E8527A" opacity="0.64"/>
        <circle  cx="160" cy="122" r="10" fill="#F5C842"/>
        <circle  cx="160" cy="122" r="4.5" fill="#E8527A"/>
        <ellipse cx="196" cy="64" rx="17" ry="12" transform="rotate(-30 196 64)" fill="#F5C842" opacity="0.86"/>
        <circle  cx="196" cy="64" r="6.5" fill="#E05A3A" opacity="0.82"/>
        <circle  cx="52" cy="250" r="4.5" fill="#F5C842" opacity="0.76"/>
      </svg>
    </div>

    <!-- Hero content -->
    <div class="relative z-10 max-w-2xl mx-auto px-6 text-center py-36 md:py-44">

      <div class="animate-fade-in inline-flex items-center gap-2 px-4 py-1.5 rounded-full mb-7" style="background:#E8527A14; border:1px solid #E8527A38;">
        <span style="color:#E8527A;" class="font-body text-xs tracking-[0.15em] uppercase" style="font-weight:700;">Fertility Awareness · Cycle Health · Functional Medicine</span>
      </div>

      <h1 class="animate-slide-up font-display font-light leading-[1.06] mb-6" style="font-size:clamp(2.9rem,7.5vw,5.6rem); color:#2D5A6B; letter-spacing:-0.015em;">
        Finally understand<br/>your cycle —<br/><em style="font-style:italic; color:#E05A3A;">naturally.</em>
      </h1>

      <p class="animate-slide-up delay-200 font-body font-light leading-relaxed mb-10 max-w-xl mx-auto" style="font-size:1.125rem; color:#2D5A6B;">
        Floreth guides you through fertility awareness and holistic cycle health — no hormones, no confusion, just the body literacy every woman deserves.
      </p>

      <div class="animate-slide-up delay-300 flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="#join"
           class="inline-flex items-center gap-2.5 px-8 py-4 rounded-full font-body text-white text-sm tracking-wide"
           style="background:#E05A3A; box-shadow:0 6px 28px #E05A3A44; min-height:52px; font-weight:700;">
          Get early access
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="#how-it-works"
           class="inline-flex items-center gap-2 px-8 py-4 rounded-full font-body text-sm tracking-wide"
           style="background:rgba(253,250,245,0.75); border:1.5px solid #2D5A6B38; color:#2D5A6B; min-height:52px; backdrop-filter:blur(8px); font-weight:400;">
          See how it works
        </a>
      </div>

      <p class="animate-fade-in delay-500 mt-8 font-body font-light text-xs tracking-wide" style="color:#2D5A6B70;">
        No hormones. No devices. No subscription needed to start.
      </p>
    </div>

    <div class="absolute bottom-0 left-0 right-0 floral-divider" aria-hidden="true">
      <svg viewBox="0 0 1440 72" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,36 C180,72 360,0 540,36 C720,72 900,8 1080,36 C1260,64 1380,20 1440,36 L1440,72 L0,72 Z" fill="#FFF8F0"/>
      </svg>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════
       PROBLEM — Three pain points
  ══════════════════════════════════════════════════════════════════════ -->
  <section class="relative py-20 md:py-28" style="background:#FFF8F0;">
    <div class="max-w-5xl mx-auto px-6">

      <div class="text-center mb-16 animate-slide-up">
        <p class="font-body text-xs tracking-[0.18em] uppercase mb-4" style="color:#E05A3A; font-weight:700;">Sound familiar?</p>
        <h2 class="font-display font-light leading-tight" style="font-size:clamp(2rem,4.5vw,3.2rem); color:#2D5A6B;">
          Your body has a rhythm.<br/><em style="font-style:italic;">Are you listening?</em>
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <div class="animate-slide-up p-8 rounded-[20px]" style="background:#FDFAF5; border:1.5px solid #E05A3A22; box-shadow:0 4px 20px #E05A3A0A;">
          <div class="w-12 h-12 rounded-full flex items-center justify-center mb-5" style="background:#E05A3A15;">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#E05A3A" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          </div>
          <h3 class="font-display mb-3" style="font-size:1.3rem; color:#2D5A6B; font-weight:500;">Hormones that silence you</h3>
          <p class="font-body font-light leading-relaxed text-base" style="color:#2D5A6B90;">Synthetic hormones mask your cycle's signals — leaving you disconnected from your own body for years without knowing what's underneath.</p>
        </div>

        <div class="animate-slide-up delay-100 p-8 rounded-[20px]" style="background:#FDFAF5; border:1.5px solid #E8527A22; box-shadow:0 4px 20px #E8527A0A;">
          <div class="w-12 h-12 rounded-full flex items-center justify-center mb-5" style="background:#E8527A15;">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#E8527A" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/><circle cx="12" cy="12" r="10"/></svg>
          </div>
          <h3 class="font-display mb-3" style="font-size:1.3rem; color:#2D5A6B; font-weight:500;">Cold data, zero context</h3>
          <p class="font-body font-light leading-relaxed text-base" style="color:#2D5A6B90;">Most apps give you numbers and graphs but never explain what they mean — leaving you more confused than when you started.</p>
        </div>

        <div class="animate-slide-up delay-200 p-8 rounded-[20px]" style="background:#FDFAF5; border:1.5px solid #6B8F5E22; box-shadow:0 4px 20px #6B8F5E0A;">
          <div class="w-12 h-12 rounded-full flex items-center justify-center mb-5" style="background:#6B8F5E15;">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#6B8F5E" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          </div>
          <h3 class="font-display mb-3" style="font-size:1.3rem; color:#2D5A6B; font-weight:500;">No app honors the whole you</h3>
          <p class="font-body font-light leading-relaxed text-base" style="color:#2D5A6B90;">Clinical white interfaces. Cosmic dark themes. Nothing designed for a woman who wants scientific precision and genuine warmth — until now.</p>
        </div>

      </div>
    </div>

    <div class="floral-divider mt-0" aria-hidden="true">
      <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,30 C360,60 720,0 1080,30 C1260,45 1380,18 1440,30 L1440,60 L0,60 Z" fill="#FDFAF5"/>
      </svg>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════
       HOW IT WORKS — 3 offset steps
  ══════════════════════════════════════════════════════════════════════ -->
  <section id="how-it-works" class="relative py-24 md:py-36" style="background:#FDFAF5;">
    <div class="max-w-4xl mx-auto px-6">

      <div class="text-center mb-20 animate-slide-up">
        <p class="font-body text-xs tracking-[0.18em] uppercase mb-4" style="color:#E8527A; font-weight:700;">The Floreth Method</p>
        <h2 class="font-display font-light leading-tight" style="font-size:clamp(2rem,4.5vw,3.4rem); color:#2D5A6B;">
          Three steps to knowing<br/><em style="font-style:italic; color:#E05A3A;">your body completely</em>
        </h2>
      </div>

      <div class="space-y-8">

        <div class="animate-slide-up flex flex-col md:flex-row gap-8 items-center p-8 md:p-10 rounded-[24px]" style="background:linear-gradient(135deg,#E05A3A0B 0%,#FDFAF5 100%); border:1.5px solid #E05A3A1E;">
          <div class="flex-shrink-0 w-16 h-16 rounded-full flex items-center justify-center" style="background:#E05A3A; box-shadow:0 6px 20px #E05A3A40;">
            <span class="font-display font-light text-white" style="font-size:1.6rem;">1</span>
          </div>
          <div>
            <h3 class="font-display mb-2" style="font-size:1.5rem; color:#2D5A6B; font-weight:500;">Chart your natural biomarkers</h3>
            <p class="font-body font-light leading-relaxed text-lg" style="color:#2D5A6B90;">Log basal body temperature, cervical fluid, and daily observations. Floreth maps your unique cycle using evidence-based Fertility Awareness Methods — no wearables, no guesswork.</p>
          </div>
        </div>

        <div class="animate-slide-up delay-150 flex flex-col md:flex-row gap-8 items-center p-8 md:p-10 rounded-[24px] md:ml-8" style="background:linear-gradient(135deg,#E8527A0B 0%,#FDFAF5 100%); border:1.5px solid #E8527A1E;">
          <div class="flex-shrink-0 w-16 h-16 rounded-full flex items-center justify-center" style="background:#E8527A; box-shadow:0 6px 20px #E8527A40;">
            <span class="font-display font-light text-white" style="font-size:1.6rem;">2</span>
          </div>
          <div>
            <h3 class="font-display mb-2" style="font-size:1.5rem; color:#2D5A6B; font-weight:500;">Learn what each phase means</h3>
            <p class="font-body font-light leading-relaxed text-lg" style="color:#2D5A6B90;">Your cycle has four distinct phases — each with its own hormonal signature, energy, and needs. Floreth translates the science into language you'll actually use every day.</p>
          </div>
        </div>

        <div class="animate-slide-up delay-300 flex flex-col md:flex-row gap-8 items-center p-8 md:p-10 rounded-[24px] md:ml-16" style="background:linear-gradient(135deg,#6B8F5E0B 0%,#FDFAF5 100%); border:1.5px solid #6B8F5E1E;">
          <div class="flex-shrink-0 w-16 h-16 rounded-full flex items-center justify-center" style="background:#6B8F5E; box-shadow:0 6px 20px #6B8F5E40;">
            <span class="font-display font-light text-white" style="font-size:1.6rem;">3</span>
          </div>
          <div>
            <h3 class="font-display mb-2" style="font-size:1.5rem; color:#2D5A6B; font-weight:500;">Live in sync with your cycle</h3>
            <p class="font-body font-light leading-relaxed text-lg" style="color:#2D5A6B90;">Whether you're avoiding pregnancy naturally, trying to conceive, or just managing your energy — Floreth gives you the body literacy to make informed, confident decisions every day.</p>
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════
       FEATURES GRID — Six color-blocked cards
  ══════════════════════════════════════════════════════════════════════ -->
  <section class="relative py-24 md:py-36 overflow-hidden" style="background:#FFF8F0;">

    <div class="absolute right-[-80px] top-1/2 -translate-y-1/2 w-[420px] pointer-events-none" aria-hidden="true" style="opacity:0.035;">
      <svg viewBox="0 0 420 420" fill="none" xmlns="http://www.w3.org/2000/svg">
        <ellipse cx="210" cy="210" rx="190" ry="190" fill="#E05A3A"/>
        <ellipse cx="210" cy="210" rx="190" ry="190" transform="rotate(36 210 210)" fill="#E8527A"/>
        <ellipse cx="210" cy="210" rx="190" ry="190" transform="rotate(72 210 210)" fill="#F5C842"/>
        <circle  cx="210" cy="210" r="55" fill="#2D5A6B"/>
      </svg>
    </div>

    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-20 animate-slide-up">
        <p class="font-body text-xs tracking-[0.18em] uppercase mb-4" style="color:#6B8F5E; font-weight:700;">What you get</p>
        <h2 class="font-display font-light leading-tight" style="font-size:clamp(2rem,4.5vw,3.4rem); color:#2D5A6B;">
          Everything your body<br/><em style="font-style:italic;">has been waiting for</em>
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">

        <div class="animate-slide-up p-7 rounded-[20px] hover:-translate-y-1 transition-transform duration-200" style="background:#FFF0EC; border:1.5px solid #E05A3A22;">
          <div class="w-11 h-11 rounded-full flex items-center justify-center mb-5" style="background:#E05A3A20;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#E05A3A" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <h3 class="font-display mb-2" style="font-size:1.2rem; color:#2D5A6B; font-weight:500;">Cycle Charting</h3>
          <p class="font-body font-light text-sm leading-relaxed" style="color:#2D5A6B90;">BBT, cervical fluid, and symptom logging — visualized as a living chart that tells your cycle's story.</p>
        </div>

        <div class="animate-slide-up delay-100 p-7 rounded-[20px] hover:-translate-y-1 transition-transform duration-200" style="background:#FFF0F5; border:1.5px solid #E8527A22;">
          <div class="w-11 h-11 rounded-full flex items-center justify-center mb-5" style="background:#E8527A20;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#E8527A" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
          </div>
          <h3 class="font-display mb-2" style="font-size:1.2rem; color:#2D5A6B; font-weight:500;">Fertility Awareness</h3>
          <p class="font-body font-light text-sm leading-relaxed" style="color:#2D5A6B90;">Creighton, Billings, and Sympto-Thermal methods explained clearly so you know your fertile window with confidence.</p>
        </div>

        <div class="animate-slide-up delay-200 p-7 rounded-[20px] hover:-translate-y-1 transition-transform duration-200" style="background:#FFFBEC; border:1.5px solid #F5C84222;">
          <div class="w-11 h-11 rounded-full flex items-center justify-center mb-5" style="background:#F5C84220;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#b8890a" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>
          </div>
          <h3 class="font-display mb-2" style="font-size:1.2rem; color:#2D5A6B; font-weight:500;">Hormone Health</h3>
          <p class="font-body font-light text-sm leading-relaxed" style="color:#2D5A6B90;">Understand estrogen, progesterone, and thyroid patterns — and what your chart reveals about your overall hormonal health.</p>
        </div>

        <div class="animate-slide-up delay-100 p-7 rounded-[20px] hover:-translate-y-1 transition-transform duration-200" style="background:#F2F8EF; border:1.5px solid #6B8F5E22;">
          <div class="w-11 h-11 rounded-full flex items-center justify-center mb-5" style="background:#6B8F5E20;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#6B8F5E" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3 class="font-display mb-2" style="font-size:1.2rem; color:#2D5A6B; font-weight:500;">Cycle Syncing</h3>
          <p class="font-body font-light text-sm leading-relaxed" style="color:#2D5A6B90;">Align your nutrition, movement, and rest with each phase's natural energy — and stop fighting your own biology.</p>
        </div>

        <div class="animate-slide-up delay-200 p-7 rounded-[20px] hover:-translate-y-1 transition-transform duration-200" style="background:#EFF4F7; border:1.5px solid #2D5A6B22;">
          <div class="w-11 h-11 rounded-full flex items-center justify-center mb-5" style="background:#2D5A6B18;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2D5A6B" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          </div>
          <h3 class="font-display mb-2" style="font-size:1.2rem; color:#2D5A6B; font-weight:500;">Functional Medicine Lens</h3>
          <p class="font-body font-light text-sm leading-relaxed" style="color:#2D5A6B90;">Your cycle connects to gut health, sleep, stress, and thyroid. Floreth teaches the whole picture — not isolated symptoms.</p>
