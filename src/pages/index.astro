---
import Base from '../layouts/Base.astro';
---

<Base
  title="Floreth — Know your body. Honor your design."
  description="Floreth is a premium Christian fertility and cycle tracking platform rooted in holistic and functional medicine. Faith-grounded wellness for women who want to understand their bodies as fearfully and wonderfully made."
>

  <!-- ═══════════════════════════════════════════════════════════════════
       HERO — Immersive warm morning-light atmospheric opening
  ══════════════════════════════════════════════════════════════════════ -->
  <section class="hero-section relative min-h-screen flex flex-col items-center justify-center overflow-hidden">

    <!-- Layered gradient background: warm apricot morning light -->
    <div class="hero-bg absolute inset-0" aria-hidden="true"></div>

    <!-- Noise/grain overlay for linen texture -->
    <div class="hero-grain absolute inset-0" aria-hidden="true"></div>

    <!-- Botanical SVG illustration — top-right -->
    <div class="absolute top-0 right-0 w-[340px] md:w-[480px] opacity-25 pointer-events-none select-none" aria-hidden="true">
      <svg viewBox="0 0 480 520" fill="none" xmlns="http://www.w3.org/2000/svg">
        <!-- Branch -->
        <path d="M420 0 C380 80 340 120 300 180 C270 230 260 280 240 340" stroke="#8EA98A" stroke-width="1.5" fill="none" stroke-linecap="round"/>
        <!-- Leaves -->
        <ellipse cx="370" cy="70" rx="28" ry="14" transform="rotate(-35 370 70)" fill="#8EA98A" opacity="0.6"/>
        <ellipse cx="348" cy="110" rx="22" ry="11" transform="rotate(20 348 110)" fill="#C97B5A" opacity="0.35"/>
        <ellipse cx="318" cy="160" rx="26" ry="12" transform="rotate(-50 318 160)" fill="#8EA98A" opacity="0.5"/>
        <ellipse cx="292" cy="210" rx="20" ry="10" transform="rotate(15 292 210)" fill="#F2C97E" opacity="0.45"/>
        <ellipse cx="272" cy="255" rx="24" ry="11" transform="rotate(-40 272 255)" fill="#8EA98A" opacity="0.55"/>
        <ellipse cx="258" cy="300" rx="18" ry="9" transform="rotate(25 258 300)" fill="#C97B5A" opacity="0.30"/>
        <!-- Small flowers -->
        <circle cx="388" cy="48" r="5" fill="#F2C97E" opacity="0.7"/>
        <circle cx="388" cy="48" r="2" fill="#C97B5A" opacity="0.8"/>
        <circle cx="335" cy="138" r="4" fill="#F2C97E" opacity="0.6"/>
        <circle cx="335" cy="138" r="1.5" fill="#C97B5A" opacity="0.7"/>
        <!-- Petals around flowers -->
        <ellipse cx="388" cy="41" rx="4" ry="2.5" fill="#F2C97E" opacity="0.5"/>
        <ellipse cx="395" cy="48" rx="4" ry="2.5" transform="rotate(90 395 48)" fill="#F2C97E" opacity="0.5"/>
        <ellipse cx="388" cy="55" rx="4" ry="2.5" fill="#F2C97E" opacity="0.5"/>
        <ellipse cx="381" cy="48" rx="4" ry="2.5" transform="rotate(90 381 48)" fill="#F2C97E" opacity="0.5"/>
      </svg>
    </div>

    <!-- Botanical SVG illustration — bottom-left -->
    <div class="absolute bottom-0 left-0 w-[260px] md:w-[360px] opacity-20 pointer-events-none select-none" aria-hidden="true">
      <svg viewBox="0 0 360 320" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0 320 C40 260 80 220 120 170 C150 130 170 90 200 50" stroke="#8EA98A" stroke-width="1.5" fill="none" stroke-linecap="round"/>
        <ellipse cx="60" cy="280" rx="30" ry="13" transform="rotate(40 60 280)" fill="#8EA98A" opacity="0.55"/>
        <ellipse cx="95" cy="238" rx="25" ry="11" transform="rotate(-20 95 238)" fill="#C97B5A" opacity="0.30"/>
        <ellipse cx="128" cy="195" rx="28" ry="12" transform="rotate(45 128 195)" fill="#8EA98A" opacity="0.50"/>
        <ellipse cx="155" cy="155" rx="22" ry="10" transform="rotate(-15 155 155)" fill="#F2C97E" opacity="0.40"/>
        <circle cx="45" cy="295" r="4" fill="#F2C97E" opacity="0.65"/>
        <circle cx="45" cy="295" r="1.5" fill="#C97B5A" opacity="0.75"/>
      </svg>
    </div>

    <!-- Hero content -->
    <div class="relative z-10 max-w-3xl mx-auto px-6 text-center py-32 md:py-40">

      <!-- Eyebrow -->
      <p class="animate-fade-in text-brand-500 font-body font-500 text-sm tracking-[0.18em] uppercase mb-6">
        Faith · Cycle Science · Functional Wellness
      </p>

      <!-- Headline — dramatic Cormorant Garamond -->
      <h1 class="animate-slide-up font-display font-light text-surface-900 leading-[1.08] tracking-tight mb-8"
          style="font-size: clamp(2.8rem, 7vw, 5.5rem); letter-spacing: -0.01em;">
        Your Cycle Is a Gift —<br />
        <em style="font-style: italic; font-weight: 300;">Learn to Read It</em>
      </h1>

      <!-- Sub -->
      <p class="animate-slide-up delay-200 font-body font-light text-surface-800 leading-relaxed mb-10 max-w-2xl mx-auto"
         style="font-size: 1.125rem;">
        Floreth blends faith, functional medicine, and fertility awareness so you can understand, trust, and honor your body's natural design.
      </p>

      <!-- CTAs -->
      <div class="animate-slide-up delay-300 flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="#join"
           class="inline-flex items-center gap-2 px-8 py-4 bg-brand-500 text-white font-body font-medium text-sm tracking-wide rounded-full hover:bg-brand-600 transition-colors duration-200 shadow-lg"
           style="box-shadow: 0 4px 24px oklch(0.62 0.10 42 / 0.28);">
          Begin my journey
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="#how-it-works"
           class="inline-flex items-center gap-2 px-8 py-4 bg-surface-100/60 backdrop-blur-sm text-surface-900 font-body font-medium text-sm tracking-wide rounded-full border border-surface-200 hover:bg-surface-200/60 transition-colors duration-200">
          See how it works
        </a>
      </div>

      <!-- Micro trust -->
      <p class="animate-fade-in delay-500 mt-8 text-xs text-surface-800/50 font-body font-light tracking-wide">
        No subscription required to explore · Faith-grounded · Science-backed
      </p>
    </div>

    <!-- Bottom wave fade into next section -->
    <div class="absolute bottom-0 left-0 right-0 wave-divider" aria-hidden="true">
      <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,40 C240,80 480,0 720,40 C960,80 1200,0 1440,40 L1440,80 L0,80 Z"
              fill="oklch(0.985 0.008 75)"/>
      </svg>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════
       IMPACT STATS — Three honest, grounding numbers
  ══════════════════════════════════════════════════════════════════════ -->
  <section class="relative py-16 md:py-20" style="background: oklch(0.985 0.008 75);">
    <div class="max-w-4xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-4 text-center">

        <div class="animate-slide-up">
          <p class="font-display font-light text-brand-500 leading-none mb-2"
             style="font-size: clamp(2.8rem, 5vw, 4rem);">28</p>
          <p class="text-xs font-body font-medium tracking-[0.12em] uppercase text-surface-800/60">Days in your cycle story</p>
        </div>

        <div class="animate-slide-up delay-100">
          <p class="font-display font-light text-brand-500 leading-none mb-2"
             style="font-size: clamp(2.8rem, 5vw, 4rem);">100%</p>
          <p class="text-xs font-body font-medium tracking-[0.12em] uppercase text-surface-800/60">Hormone-free family planning</p>
        </div>

        <div class="animate-slide-up delay-200">
          <p class="font-display font-light text-brand-500 leading-none mb-2"
             style="font-size: clamp(2.8rem, 5vw, 4rem);">1 in 1</p>
          <p class="text-xs font-body font-medium tracking-[0.12em] uppercase text-surface-800/60">Women deserve to know her body</p>
        </div>

      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════
       ORIGIN STORY — Narrative, offset layout, pull quote
  ══════════════════════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden py-24 md:py-36" style="background: oklch(0.97 0.015 75);">

    <!-- Faint botanical watermark -->
    <div class="absolute right-[-60px] top-1/2 -translate-y-1/2 opacity-[0.07] pointer-events-none select-none w-[400px]" aria-hidden="true">
      <svg viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="200" cy="200" r="180" stroke="#C97B5A" stroke-width="1.5"/>
        <circle cx="200" cy="200" r="140" stroke="#C97B5A" stroke-width="1"/>
        <circle cx="200" cy="200" r="100" stroke="#C97B5A" stroke-width="0.8"/>
        <path d="M200 20 L200 380 M20 200 L380 200" stroke="#C97B5A" stroke-width="0.6"/>
        <path d="M75 75 L325 325 M325 75 L75 325" stroke="#C97B5A" stroke-width="0.6"/>
      </svg>
    </div>

    <div class="max-w-5xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">

        <!-- Left: Story text -->
        <div class="animate-slide-up">
          <p class="text-brand-500 font-body font-medium text-xs tracking-[0.18em] uppercase mb-5">Our Story</p>
          <h2 class="font-display font-light text-surface-900 leading-tight mb-8"
              style="font-size: clamp(2rem, 4vw, 3.2rem);">
            Built for women who felt lost<br />
            <em style="font-style: italic;">between science and faith</em>
          </h2>
          <p class="font-body font-light text-surface-800 leading-relaxed text-lg mb-6">
            Most cycle apps treat fertility as a problem to solve — or a data set to optimize. They offer charts and algorithms, but no language for the sacred, no respect for the woman behind the numbers.
          </p>
          <p class="font-body font-light text-surface-800 leading-relaxed text-lg mb-6">
            Floreth was born from a different belief: that your body, as Psalm 139 describes, is <em>fearfully and wonderfully made</em>. Every phase of your cycle is intelligible, purposeful, and worth understanding — not suppressing.
          </p>
          <p class="font-body font-light text-surface-800 leading-relaxed text-lg">
            We bring together evidence-based Fertility Awareness Methods, functional medicine cycle literacy, and Christian wellness education — in an experience that feels like opening a beautiful journal, not a medical record.
          </p>
        </div>

        <!-- Right: Pull quote card -->
        <div class="animate-slide-up delay-200 flex flex-col gap-6">

          <!-- Quote card -->
          <div class="relative p-10 rounded-[28px]"
               style="background: oklch(0.97 0.015 75); border: 1px solid oklch(0.90 0.025 55); box-shadow: 0 8px 40px oklch(0.62 0.10 42 / 0.08);">
            <!-- Decorative botanical accent -->
            <div class="absolute top-4 right-4 opacity-30" aria-hidden="true">
              <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
                <circle cx="24" cy="24" r="20" stroke="#8EA98A" stroke-width="1"/>
                <ellipse cx="24" cy="14" rx="5" ry="10" fill="#8EA98A" opacity="0.4"/>
                <ellipse cx="14" cy="29" rx="10" ry="5" transform="rotate(-30 14 29)" fill="#8EA98A" opacity="0.3"/>
                <ellipse cx="34" cy="29" rx="10" ry="5" transform="rotate(30 34 29)" fill="#8EA98A" opacity="0.3"/>
                <circle cx="24" cy="24" r="3" fill="#C97B5A" opacity="0.6"/>
              </svg>
            </div>
            <p class="font-display font-light italic text-surface-900 leading-snug mb-6"
               style="font-size: 1.5rem; line-height: 1.4;">
              "I will praise You, for I am fearfully and wonderfully made; marvelous are Your works, and that my soul knows very well."
            </p>
            <p class="font-body font-medium text-brand-500 text-xs tracking-[0.15em] uppercase">Psalm 139:14</p>
          </div>

          <!-- Small accent card -->
          <div class="p-6 rounded-[20px]"
               style="background: oklch(0.85 0.10 75 / 0.18); border: 1px solid oklch(0.85 0.10 75 / 0.35);">
            <p class="font-body font-light text-surface-900 text-base leading-relaxed">
              <span class="font-medium">Floreth</span> combines the Latin <em>florere</em> (to flourish) with breath — because understanding your cycle is how you come alive in your own skin.
            </p>
          </div>

        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════
       HOW IT WORKS — 4 steps, visual timeline feel
  ══════════════════════════════════════════════════════════════════════ -->
  <section id="how-it-works" class="relative py-24 md:py-36 overflow-hidden" style="background: oklch(0.985 0.008 75);">

    <!-- Top wave -->
    <div class="absolute top-0 left-0 right-0 wave-divider rotate-180" aria-hidden="true">
      <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,20 C360,60 720,0 1080,30 C1260,45 1380,20 1440,20 L1440,60 L0,60 Z"
              fill="oklch(0.97 0.015 75)"/>
      </svg>
    </div>

    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-20 animate-slide-up">
        <p class="text-brand-500 font-body font-medium text-xs tracking-[0.18em] uppercase mb-4">The Floreth Method</p>
        <h2 class="font-display font-light text-surface-900 leading-tight"
            style="font-size: clamp(2rem, 4.5vw, 3.4rem);">
          Four seasons of your month,<br />
          <em style="font-style: italic;">finally understood</em>
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-10">

        <!-- Step 1 -->
        <div class="animate-slide-up group p-8 rounded-[24px] transition-shadow duration-300 hover:shadow-xl"
             style="background: oklch(0.97 0.015 75); border: 1px solid oklch(0.90 0.025 55); box-shadow: 0 4px 20px oklch(0.62 0.10 42 / 0.06);">
          <div class="flex items-start gap-5">
            <div class="flex-shrink-0 w-12 h-12 rounded-full flex items-center justify-center font-display font-light text-xl text-white"
                 style="background: oklch(0.62 0.10 42);">1</div>
            <div>
              <h3 class="font-display font-medium text-surface-900 mb-3" style="font-size: 1.35rem;">Track your biomarkers</h3>
              <p class="font-body font-light text-surface-800 leading-relaxed text-base">
                Log temperature, cervical fluid, and observations each morning. Floreth reads these signs with FAM-certified methods to map your unique cycle.
              </p>
            </div>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="animate-slide-up delay-100 group p-8 rounded-[24px] transition-shadow duration-300 hover:shadow-xl"
             style="background: oklch(0.94 0.022 60); border: 1px solid oklch(0.90 0.025 55); box-shadow: 0 4px 20px oklch(0.62 0.10 42 / 0.06);">
          <div class="flex items-start gap-5">
            <div class="flex-shrink-0 w-12 h-12 rounded-full flex items-center justify-center font-display font-light text-xl text-white"
                 style="background: oklch(0.68 0.052 148);">2</div>
            <div>
              <h3 class="font-display font-medium text-surface-900 mb-3" style="font-size: 1.35rem;">Understand your phases</h3>
              <p class="font-body font-light text-surface-800 leading-relaxed text-base">
                See your cycle as four distinct seasons — each with its own energy, nutrition, and spiritual rhythm. Our phase guides connect the physical to the purposeful.
              </p>
            </div>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="animate-slide-up delay-200 group p-8 rounded-[24px] transition-shadow duration-300 hover:shadow-xl"
             style="background: oklch(0.93 0.065 75); border: 1px solid oklch(0.88 0.09 75 / 0.5); box-shadow: 0 4px 20px oklch(0.62 0.10 42 / 0.06);">
          <div class="flex items-start gap-5">
            <div class="flex-shrink-0 w-12 h-12 rounded-full flex items-center justify-center font-display font-light text-xl text-white"
                 style="background: oklch(0.76 0.10 75);">3</div>
            <div>
              <h3 class="font-display font-medium text-surface-900 mb-3" style="font-size: 1.35rem;">Learn the deeper why</h3>
              <p class="font-body font-light text-surface-800 leading-relaxed text-base">
                Dive into Floreth's functional medicine education library — hormone health, gut-cycle connections, thyroid support, and the theology of embodiment.
              </p>
            </div>
          </div>
        </div>

        <!-- Step 4 -->
        <div class="animate-slide-up delay-300 group p-8 rounded-[24px] transition-shadow duration-300 hover:shadow-xl"
             style="background: oklch(0.97 0.015 75); border: 1px solid oklch(0.90 0.025 55); box-shadow: 0 4px 20px oklch(0.62 0.10 42 / 0.06);">
          <div class="flex items-start gap-5">
            <div class="flex-shrink-0 w-12 h-12 rounded-full flex items-center justify-center font-display font-light text-xl text-white"
                 style="background: oklch(0.62 0.10 42);">4</div>
            <div>
              <h3 class="font-display font-medium text-surface-900 mb-3" style="font-size: 1.35rem;">Honor your design</h3>
              <p class="font-body font-light text-surface-800 leading-relaxed text-base">
                Whether you're charting for conception, avoiding pregnancy naturally, or simply knowing yourself — Floreth meets you with science and reverence, not judgment.
              </p>
            </div>
          </div>
        </div>

      </div>
    </div>

    <!-- Bottom wave -->
    <div class="absolute bottom-0 left-0 right-0 wave-divider" aria-hidden="true">
      <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,20 C360,60 720,0 1080,30 C1260,45 1380,20 1440,20 L1440,60 L0,60 Z"
              fill="oklch(0.97 0.015 75)"/>
      </svg>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════
       VALUES / PRINCIPLES — Staggered organic cards
  ══════════════════════════════════════════════════════════════════════ -->
  <section class="relative py-24 md:py-36" style="background: oklch(0.97 0.015 75);">
    <div class="max-w-5xl mx-auto px-6">

      <div class="text-center mb-20 animate-slide-up">
        <p class="text-brand-500 font-body font-medium text-xs tracking-[0.18em] uppercase mb-4">What We Believe</p>
        <h2 class="font-display font-light text-surface-900 leading-tight"
            style="font-size: clamp(2rem, 4.5vw, 3.4rem);">
          Rooted in faith.<br />
          <em style="font-style: italic;">Grounded in science.</em>
        </h2>
      </div>

      <!-- Asymmetric staggered grid -->
      <div class="space-y-6">

        <!-- Row 1: full-width feature -->
        <div class="animate-slide-up p-10 md:p-14 rounded-[28px] flex flex-col md:flex-row gap-10 items-center"
             style="background: linear-gradient(135deg, oklch(0.62 0.10 42 / 0.08) 0%, oklch(0.85 0.10 75 / 0.12) 100%); border: 1px solid oklch(0.90 0.025 55);">
          <!-- Icon -->
          <div class="flex-shrink-0 w-16 h-16 rounded-full flex items-center justify-center"
               style="background: oklch(0.62 0.10 42 / 0.15);">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="oklch(0.62 0.10 42)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/>
              <path d="M12 6v6l4 2"/>
            </svg>
          </div>
          <div>
            <h3 class="font-display font-medium text-surface-900 mb-3" style="font-size: 1.5rem;">Your fertility is not a problem</h3>
            <p class="font-body font-light text-surface-800 leading-relaxed text-lg max-w-2xl">
              We reject the medical model that treats a healthy, fertile cycle as something to be suppressed. Floreth is built on the conviction that fertility awareness is healthcare — not a last resort.
            </p>
          </div>
        </div>

        <!-- Row 2: two cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

          <div class="animate-slide-up delay-100 p-8 rounded-[24px]"
               style="background: oklch(0.90 0.028 148 / 0.30); border: 1px solid oklch(0.75 0.048 148 / 0.35);">
            <div class="w-12 h-12 rounded-full flex items-center justify-center mb-5"
                 style="background: oklch(0.68 0.052 148 / 0.20);">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="oklch(0.58 0.052 148)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2z"/>
                <path d="M12 8v4l3 3"/>
              </svg>
            </div>
            <h3 class="font-display font-medium text-surface-900 mb-3" style="font-size: 1.3rem;">Functional, not fragmented</h3>
            <p class="font-body font-light text-surface-800 leading-relaxed text-base">
              Your cycle connects to your sleep, gut, thyroid, stress, and spirit. We teach the whole picture — because your body speaks in systems, not symptoms.
            </p>
          </div>

          <div class="animate-slide-up delay-200 p-8 rounded-[24px]"
               style="background: oklch(0.93 0.065 75 / 0.40); border: 1px solid oklch(0.85 0.10 75 / 0.45);">
            <div class="w-12 h-12 rounded-full flex items-center justify-center mb-5"
                 style="background: oklch(0.85 0.10 75 / 0.35);">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="oklch(0.52 0.10 42)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
              </svg>
            </div>
            <h3 class="font-display font-medium text-surface-900 mb-3" style="font-size: 1.3rem;">Faith as a foundation</h3>
            <p class="font-body font-light text-surface-800 leading-relaxed text-base">
              Christian women deserve tools built with their worldview, not adapted from secular frameworks. Our content honors the theological meaning of embodiment, fertility, and womanhood.
            </p>
          </div>

        </div>

        <!-- Row 3: offset third card -->
        <div class="animate-slide-up delay-300 md:mx-16 p-8 rounded-[24px] text-center"
             style="background: oklch(0.94 0.022 60); border: 1px solid oklch(0.90 0.025 55);">
          <div class="w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-5"
               style="background: oklch(0.62 0.10 42 / 0.15);">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="oklch(0.62 0.10 42)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <h3 class="font-display font-medium text-surface-900 mb-3" style="font-size: 1.3rem;">Privacy by principle</h3>
          <p class="font-body font-light text-surface-800 leading-relaxed text-base max-w-md mx-auto">
            Your cycle data is sacred and private. Floreth will never sell, share, or monetize your health information. What you chart stays yours.
          </p>
        </div>

      </div>
