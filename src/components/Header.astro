---
<header class="sticky top-0 z-50" style="border-bottom:1px solid #E05A3A18; background:rgba(253,250,245,0.90);">
  <div class="absolute inset-0" style="backdrop-filter:blur(12px); z-index:-1;" aria-hidden="true"></div>
  <nav class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">

    <!-- Wordmark + botanical mark -->
    <a href="/" class="flex items-center gap-2.5" aria-label="Floreth home">
      <svg width="26" height="26" viewBox="0 0 26 26" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" class="flex-shrink-0">
        <ellipse cx="13" cy="5"  rx="4" ry="7" fill="#E05A3A" opacity="0.88"/>
        <ellipse cx="13" cy="5"  rx="4" ry="7" transform="rotate(72 13 13)"  fill="#E8527A" opacity="0.78"/>
        <ellipse cx="13" cy="5"  rx="4" ry="7" transform="rotate(144 13 13)" fill="#F5C842" opacity="0.80"/>
        <ellipse cx="13" cy="5"  rx="4" ry="7" transform="rotate(216 13 13)" fill="#E05A3A" opacity="0.72"/>
        <ellipse cx="13" cy="5"  rx="4" ry="7" transform="rotate(288 13 13)" fill="#E8527A" opacity="0.72"/>
        <circle  cx="13" cy="13" r="4" fill="#F5C842"/>
        <circle  cx="13" cy="13" r="2" fill="#E05A3A"/>
      </svg>
      <span class="font-display font-medium" style="font-size:1.25rem; letter-spacing:0.04em; color:#2D5A6B;">Floreth</span>
    </a>

    <!-- Nav links -->
    <div class="hidden md:flex items-center gap-8">
      <a href="#how-it-works" class="font-body font-light text-sm" style="color:#2D5A6B80; transition:color 150ms;">How it works</a>
      <a href="#join"         class="font-body font-light text-sm" style="color:#2D5A6B80; transition:color 150ms;">About</a>
    </div>

    <!-- CTA -->
    <a href="#join"
       class="inline-flex items-center gap-1.5 px-5 py-2.5 rounded-full font-body text-sm text-white"
       style="background:#E05A3A; box-shadow:0 3px 14px #E05A3A38; font-weight:700; min-height:44px;">
      Get early access
    </a>

  </nav>
</header>
