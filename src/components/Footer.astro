---
const year = new Date().getFullYear();
---
<footer style="background: oklch(0.25 0.025 42); border-top: 1px solid oklch(0.35 0.025 42);">
  <div class="max-w-5xl mx-auto px-6 py-14">

    <!-- Top row: brand + tagline -->
    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-10 pb-10"
         style="border-bottom: 1px solid oklch(0.35 0.025 42 / 0.6);">

      <!-- Brand block -->
      <div class="max-w-xs">
        <div class="flex items-center gap-2.5 mb-4">
          <svg width="20" height="20" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <ellipse cx="11" cy="5.5" rx="3.5" ry="5.5" fill="oklch(0.85 0.10 75)" opacity="0.6"/>
            <ellipse cx="11" cy="5.5" rx="3.5" ry="5.5" fill="oklch(0.85 0.10 75)" opacity="0.35" transform="rotate(72 11 11)"/>
            <ellipse cx="11" cy="5.5" rx="3.5" ry="5.5" fill="oklch(0.85 0.10 75)" opacity="0.35" transform="rotate(144 11 11)"/>
            <ellipse cx="11" cy="5.5" rx="3.5" ry="5.5" fill="oklch(0.85 0.10 75)" opacity="0.35" transform="rotate(216 11 11)"/>
            <ellipse cx="11" cy="5.5" rx="3.5" ry="5.5" fill="oklch(0.85 0.10 75)" opacity="0.35" transform="rotate(288 11 11)"/>
            <circle cx="11" cy="11" r="2.5" fill="oklch(0.85 0.10 75)"/>
          </svg>
          <span class="font-display font-medium tracking-wide"
                style="color: oklch(0.97 0.015 75); font-size: 1.15rem; letter-spacing: 0.04em;">Floreth</span>
        </div>
        <p class="font-body font-light text-sm leading-relaxed" style="color: oklch(0.75 0.015 42);">
          Know your body. Honor your design.
        </p>
        <p class="font-body font-light text-xs leading-relaxed mt-3" style="color: oklch(0.65 0.012 42);">
          A faith-grounded, functional medicine cycle tracking platform for Christian women.
        </p>
      </div>

      <!-- Links -->
      <div class="flex flex-col sm:flex-row gap-10">
        <div>
          <p class="font-body font-medium text-xs tracking-[0.14em] uppercase mb-4" style="color: oklch(0.75 0.015 42);">Platform</p>
          <ul class="space-y-3">
            <li><a href="#how-it-works" class="font-body font-light text-sm transition-colors duration-150" style="color: oklch(0.65 0.012 42);" onmouseover="this.style.color='oklch(0.85 0.10 75)'" onmouseout="this.style.color='oklch(0.65 0.012 42)'">How it works</a></li>
            <li><a href="#join" class="font-body font-light text-sm transition-colors duration-150" style="color: oklch(0.65 0.012 42);" onmouseover="this.style.color='oklch(0.85 0.10 75)'" onmouseout="this.style.color='oklch(0.65 0.012 42)'">Join the waitlist</a></li>
          </ul>
        </div>
        <div>
          <p class="font-body font-medium text-xs tracking-[0.14em] uppercase mb-4" style="color: oklch(0.75 0.015 42);">Beliefs</p>
          <ul class="space-y-3">
            <li><a href="#" class="font-body font-light text-sm transition-colors duration-150" style="color: oklch(0.65 0.012 42);" onmouseover="this.style.color='oklch(0.85 0.10 75)'" onmouseout="this.style.color='oklch(0.65 0.012 42)'">Our mission</a></li>
            <li><a href="#" class="font-body font-light text-sm transition-colors duration-150" style="color: oklch(0.65 0.012 42);" onmouseover="this.style.color='oklch(0.85 0.10 75)'" onmouseout="this.style.color='oklch(0.65 0.012 42)'">Privacy promise</a></li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Bottom row -->
    <div class="pt-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <p class="font-body font-light text-xs" style="color: oklch(0.55 0.010 42);">
        &copy; {year} Floreth. All rights reserved.
      </p>
      <p class="font-body font-light text-xs italic" style="color: oklch(0.50 0.012 42);">
        "Fearfully and wonderfully made" — Psalm 139:14
      </p>
    </div>

  </div>
</footer>
